generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum WorkspaceRole {
  OWNER
  MEMBER
  VIEWER
}

enum SubmissionStatus {
  DRAFT
  REVIEWED
  NEEDS_REVISION
}

enum PermitType {
  BUILDING
  ELECTRICAL
  PLUMBING
  MECHANICAL
  ZONING
  GRADING
}

enum ProjectType {
  REMODEL
  ADDITION
  ADU
  NEW_CONSTRUCTION
  DECK_PATIO
  FENCE_WALL
  POOL
  DEMOLITION
  OTHER
}

enum ReviewVerdict {
  LIKELY_APPROVE
  CONDITIONAL
  LIKELY_REJECT
}

enum IssueSeverity {
  CRITICAL
  MAJOR
  MINOR
}

// ---------------------------------------------------------------------------
// Workspace + User + Membership
// ---------------------------------------------------------------------------

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     WorkspaceMember[]
  submissions Submission[]
  reviews     Review[]

  @@map("workspaces")
}

model User {
  id        String   @id // Supabase auth.users UUID — set explicitly, no default
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  workspaces WorkspaceMember[]

  @@map("users")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

// ---------------------------------------------------------------------------
// Core entities
// ---------------------------------------------------------------------------

model Submission {
  id            String           @id @default(cuid())
  workspaceId   String
  title         String
  address       String
  jurisdiction  String
  permitType    PermitType
  projectType   ProjectType
  scopeOfWork   String
  reviewContext String?          // optional: prior objections, focus areas, extra context for the reviewer
  status        SubmissionStatus @default(DRAFT)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  reviews   Review[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("submissions")
}

// ---------------------------------------------------------------------------
// Reviews — append-only, no updatedAt
// ---------------------------------------------------------------------------

model Review {
  id             String @id @default(cuid())
  workspaceId    String
  submissionId   String
  revisionNumber Int

  // Snapshot of submission state at review time
  snapshotTitle         String
  snapshotScopeOfWork   String
  snapshotJurisdiction  String
  snapshotPermitType    PermitType
  snapshotProjectType   ProjectType
  snapshotReviewContext String?
  snapshotArtifacts     String[]   // empty for V1; document refs in V2

  // AI provenance
  modelVersion  String
  promptVersion String

  // Full structured output from the model, verbatim
  rawPayload Json

  // Parsed fields (promoted for display and querying)
  verdict     ReviewVerdict
  summary     String
  missingDocs String[]

  createdAt DateTime @default(now())

  workspace  Workspace     @relation(fields: [workspaceId], references: [id])
  submission Submission    @relation(fields: [submissionId], references: [id])
  issues     ReviewIssue[]

  @@unique([submissionId, revisionNumber])
  @@index([workspaceId])
  @@index([submissionId])
  @@map("reviews")
}

model ReviewIssue {
  id            String        @id @default(cuid())
  reviewId      String
  severity      IssueSeverity
  category      String
  description   String
  codeReference String?

  review Review @relation(fields: [reviewId], references: [id])

  @@index([reviewId])
  @@map("review_issues")
}
